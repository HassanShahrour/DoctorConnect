@model IEnumerable<DoctorConnect.Models.Patient>

@{
    ViewData["Title"] = "Patients";
}

<h1>Patients</h1>

<p>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPatientModal">Create New</button>
</p>

<table class="table table-striped datatable" id="patientsTable">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.User.FirstName</td>
                <td>@p.User.LastName</td>
                <td>@p.User.Email</td>
                <td>@p.User.PhoneNumber</td>
                <td>
                    <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editPatientModal" data-id="@p.UserId" data-first="@p.User.FirstName" data-last="@p.User.LastName" data-email="@p.User.Email" data-phone="@p.User.PhoneNumber">Edit</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Create Modal -->
<div class="modal fade" id="createPatientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post" class="ajax-form">
                <div class="modal-header">
                    <h5 class="modal-title">Create Patient</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">First Name</label>
                        <input name="FirstName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Last Name</label>
                        <input name="LastName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input name="Email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input name="PhoneNumber" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editPatientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post" class="ajax-form">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Patient</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="Id" id="patientId" />
                    <div class="mb-3">
                        <label class="form-label">First Name</label>
                        <input name="FirstName" id="patientFirst" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Last Name</label>
                        <input name="LastName" id="patientLast" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input name="Email" id="patientEmail" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input name="PhoneNumber" id="patientPhone" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var editPatientModal = document.getElementById('editPatientModal');
        editPatientModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            $('#patientId').val(button.getAttribute('data-id'));
            $('#patientFirst').val(button.getAttribute('data-first'));
            $('#patientLast').val(button.getAttribute('data-last'));
            $('#patientEmail').val(button.getAttribute('data-email'));
            $('#patientPhone').val(button.getAttribute('data-phone'));
        });
    </script>
}
